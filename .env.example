# Resend API key — https://resend.com/api-keys
# Set as an environment variable in the Vercel dashboard (Project Settings → Environment Variables).
# Never commit the real value to git.
RESEND_API_KEY=

# Address that should receive quote-request emails.
# While no domain is verified in Resend, this MUST match the email address
# your Resend account is registered with — sandbox sending only delivers there.
TO_EMAIL=
